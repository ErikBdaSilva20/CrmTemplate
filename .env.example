# URL base do tenant-gateway (backend real dos dados).
# Enquanto vazio, o app NAO simula dados: as telas mostram um aviso de
# "backend nao conectado" e nada e salvo. Defina esta variavel para conectar.
# VITE_GATEWAY_URL=https://seu-gateway.exemplo.com

# Observacao: o LOGIN e mockado (src/lib/data/mock-auth.ts) e funciona sem
# backend. Credenciais de demonstracao: admin@demo.local / demo1234.
# Para integrar auth real, veja o objeto `auth` em src/lib/data/client.ts.

{
  "id": "flowcrm",
  "name": "FlowCRM",
  "description": "CRM de vendas: contatos, empresas, negócios (Kanban/BANT), atividades, tarefas, metas e dashboard. Multi-tenant pelo gateway.",
  "version": "1.0.0",
  "engine": "vite-react-gateway",
  "schemaVersion": 1,
  "migrations": ["0001_business_schema.sql"],
  "auth": { "provider": "better-auth", "roles": ["admin", "manager", "rep"] },
  "screens": [
    { "id": "dashboard", "route": "/dashboard", "title": "Dashboard", "file": "src/screens/DashboardScreen" },
    { "id": "contacts", "route": "/contacts", "title": "Contatos", "file": "src/screens/ContactsScreen" },
    { "id": "companies", "route": "/companies", "title": "Empresas", "file": "src/screens/CompaniesScreen" },
    { "id": "deals", "route": "/deals", "title": "Negócios", "file": "src/screens/DealsScreen" },
    { "id": "deal-detail", "route": "/deals/:id", "title": "Detalhe do Negócio", "file": "src/screens/DealDetailScreen" },
    { "id": "activities", "route": "/activities", "title": "Atividades", "file": "src/screens/ActivitiesScreen" },
    { "id": "tasks", "route": "/tasks", "title": "Tarefas", "file": "src/screens/TasksScreen" },
    { "id": "sales-goals", "route": "/sales-goals", "title": "Metas", "file": "src/screens/SalesGoalsScreen" },
    { "id": "segments", "route": "/segments", "title": "Filtros Salvos", "file": "src/screens/SegmentsScreen" },
    { "id": "settings", "route": "/settings", "title": "Configurações", "file": "src/screens/SettingsScreen" },
    { "id": "setup", "route": "/setup", "title": "Setup", "file": "src/screens/SetupScreen" },
    { "id": "login", "route": "/login", "title": "Entrar", "file": "src/screens/LoginScreen" }
  ],
  "editable": {
    "allow": [
      "src/screens/**",
      "src/components/crm/**",
      "src/lib/data/*.repo.ts",
      "src/lib/data/index.ts",
      "src/lib/constants.ts",
      "src/lib/format.ts",
      "src/index.css"
    ],
    "protect": [
      "src/lib/data/client.ts",
      "src/lib/data/types.gen.ts",
      "src/lib/auth.tsx",
      "src/components/ui/**",
      "src/lib/utils.ts",
      "src/main.tsx",
      "vite.config.ts",
      "components.json",
      "preview-fixtures.ts",
      "supabase/migrations/**"
    ]
  },
  "composio": { "toolkits": [] },
  "envContract": ["VITE_GATEWAY_URL"]
}
